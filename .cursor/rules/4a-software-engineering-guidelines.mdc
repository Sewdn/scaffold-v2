### State Management

#### Local Component State

Use `useState` for component-specific UI state:

```typescript
function ExpandableSection() {
  const [isExpanded, setIsExpanded] = useState(false);

  return (
    <div>
      <button onClick={() => setIsExpanded(!isExpanded)}>
        {isExpanded ? "Collapse" : "Expand"}
      </button>
      {isExpanded && <div>Expanded content</div>}
    </div>
  );
}
```

#### Derived State with useMemo

Use `useMemo` for derived state, and avoid overuse of state to avoid unnecessary recalculations:

```typescript
const filteredDocuments = useMemo(() => {
  return documents.filter(doc => {
    const matchesSearch = !searchQuery || doc.title.includes(searchQuery);
    const matchesLabels =
      !selectedLabels.length || doc.labels.some(label => selectedLabels.includes(label));
    return matchesSearch && matchesLabels;
  });
}, [documents, searchQuery, selectedLabels]);
```

#### Context for Global State

Use Context API for global state that needs to be accessed by multiple components:

```typescript
// Create context
const DocumentContext = createContext<DocumentContextType | undefined>(
  undefined
);

// Provider component
export function DocumentProvider({ children, backend }) {
  // State and methods
  const [documents, setDocuments] = useState<Document[]>([]);

  // Context value
  const contextValue = {
    documents,
    addDocument,
    removeDocument,
    // ...other methods
  };

  return (
    <DocumentContext.Provider value={contextValue}>
      {children}
    </DocumentContext.Provider>
  );
}

// Custom hook for using the context
export function useDocuments() {
  const context = useContext(DocumentContext);
  if (context === undefined) {
    throw new Error("useDocuments must be used within a DocumentProvider");
  }
  return context;
}
```

#### Persistent State

Use `localStorage` or other persistence mechanisms for state that should survive page refreshes:

```typescript
export function useFilterState() {
  const [filterState, setFilterState] = useLocalStorage<FilterState>(
    'filter-state-key',
    DEFAULT_FILTER_STATE
  );

  // Rest of the hook
}
```

### Component Props and TypeScript

#### Prop Types

Define clear interfaces for component props:

```typescript
// Define in types/component-props.ts
export interface DocumentCardProps {
  document: Document;
  onRemoveDocument: (id: string) => void;
  onAddLabel: (id: string, label: string) => void;
  isSelected?: boolean;
}

// Use in component
export function DocumentCard({
  document,
  onRemoveDocument,
  onAddLabel,
  isSelected = false,
}: DocumentCardProps) {
  // Component implementation
}
```

#### Prop Grouping

Group related props into logical interfaces:

```typescript
// Base props
export interface DocumentActionHandlers {
  onRemoveDocument: (id: string) => void;
  onAddLabel: (id: string, label: string) => void;
}

// Extended props
export interface DocumentCardProps extends DocumentActionHandlers {
  document: Document;
  isSelected?: boolean;
}
```

